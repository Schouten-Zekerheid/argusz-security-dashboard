{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "argusz/argusz",
    "type": "project",
    "description": "Open-source security dashboard for CI/CD scan results.",
    "keywords": [
        "laravel",
        "security",
        "dashboard",
        "sarif",
        "devsecops"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0",
        "laravel/nightwatch": "^1.24",
        "laravel/telescope": "^5.20",
        "laravel/tinker": "^2.10.1",
        "livewire/blaze": "^1.0",
        "livewire/livewire": "^4.0",
        "maatwebsite/excel": "^4.0",
        "mongodb/laravel-mongodb": "^5.6",
        "socialiteproviders/microsoft-azure": "^5.2",
        "spatie/browsershot": "^5.4",
        "spatie/laravel-activitylog": "^4.12",
        "spatie/laravel-pdf": "^2.11",
        "spatie/laravel-permission": "^7.2",
        "symfony/mime": "^7.4.12"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "larastan/larastan": "^3.0",
        "nunomaduro/phpinsights": "^2.11",
        "phpunit/phpunit": "^12.0",
        "rector/rector": "^2.0",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "@php artisan db:seed --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "@php artisan optimize:clear",
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74,#86efac\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" \"php artisan nightwatch:agent\" --names=server,queue,logs,vite,nightwatch --kill-others"
        ],
        "prod": [
            "npm run build",
            "@php artisan optimize"
        ],
        "dev:ssr": [
            "npm run build:ssr",
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"php artisan inertia:start-ssr\" --names=server,queue,logs,ssr --kill-others"
        ],
        "lint": [
            "pint --parallel",
            "npm run lint:blade:fix"
        ],
        "test:lint": [
            "pint --parallel --test",
            "npm run lint:blade"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@test:lint",
            "@php artisan test"
        ],
        "ci": [
            "@test:lint",
            "vendor/bin/phpstan analyse --no-progress",
            "php artisan insights app -n || true",
            "vendor/bin/rector process --dry-run --no-progress-bar",
            "composer update --dry-run",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
