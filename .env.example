APP_NAME=Argusz
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOGO=
APP_LOGO_ALT="${APP_NAME}"
# Authentication provider: "local" (email/password) or "azure" (Microsoft Entra ID).
AUTH_PROVIDER=local
SCM_PROVIDER=github

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single,nightwatch
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

DOCUMENTDB_DSN=mongodb://127.0.0.1:27017
DOCUMENTDB_DATABASE=argusz
DOCUMENTDB_TLS=false

NIGHTWATCH_SESSION_TOKEN=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Microsoft Entra ID (Azure AD)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=
AZURE_TENANT_ID=

# GitHub
GITHUB_API_URL=https://api.github.com
GITHUB_TOKEN=

# Issue tracker
ISSUE_TRACKER_PROVIDER=jira
ISSUE_TRACKER_ENABLED=false
ISSUE_TRACKER_SYNC_STATUSES=false

# Jira
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_STATUS_DONE=Done
JIRA_STATUS_REOPEN="To Do"

# SLA Thresholds (in days)
SLA_CRITICAL_DAYS=
SLA_HIGH_DAYS=
SLA_MEDIUM_DAYS=
SLA_LOW_DAYS=

# Notifications
NOTIFICATION_PROVIDER=teams
CRITICAL_FINDING_NOTIFICATIONS_ENABLED=false
TEAMS_WEBHOOK_URL=

# GitHub Actions OIDC ingest validation
OIDC_ISSUER=https://token.actions.githubusercontent.com
OIDC_JWKS_URL=https://token.actions.githubusercontent.com/.well-known/jwks
OIDC_AUDIENCE=security-dashboard
OIDC_ALLOWED_REPOSITORIES=

# Optional comma-separated email domain allowlist for admin-created users
USER_ALLOWED_EMAIL_DOMAINS=

# Telescope debug dashboard. Keep disabled outside local development.
TELESCOPE_ENABLED=false
# Data Retention
DATA_RETENTION_DAYS=30
DATA_RETENTION_BATCH_SIZE=100
DATA_RETENTION_SLEEP_MS=50
